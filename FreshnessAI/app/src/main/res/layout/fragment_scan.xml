<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Frozen Capture Preview -->
    <ImageView
        android:id="@+id/iv_captured_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scan Overlay -->
    <com.freshnessai.ui.ScanOverlayView
        android:id="@+id/scan_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scanner Line -->
    <View
        android:id="@+id/scanner_line"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/scanner_line_gradient"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Flash Overlay -->
    <View
        android:id="@+id/flash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone" />

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_button_dark"
            android:src="@drawable/ic_back"
            app:tint="@color/text_on_dark"
            android:contentDescription="Back"
            android:scaleType="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/scan_title"
            android:textColor="@color/text_on_dark"
            android:textSize="@dimen/text_subtitle"
            android:fontFamily="sans-serif-medium" />

        <ImageButton
            android:id="@+id/btn_flash"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_button_dark"
            android:src="@drawable/ic_flash"
            app:tint="@color/text_on_dark"
            android:contentDescription="Toggle flash"
            android:scaleType="center" />
    </LinearLayout>

    <!-- Bottom Instruction -->
    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_lg"
        android:background="@drawable/gradient_bottom_dark"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_scan_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_instruction"
            android:textColor="@color/text_on_dark"
            android:textSize="@dimen/text_subtitle"
            android:fontFamily="sans-serif-medium"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/tv_scan_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/scan_align_hint"
            android:textColor="#99FFFFFF"
            android:textSize="@dimen/text_caption"
            android:textAlignment="center" />

        <ImageButton
            android:id="@+id/btn_capture"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/shutter_button"
            android:contentDescription="Capture"
            android:scaleType="fitCenter" />


        <!-- Processing indicator (hidden by default) -->
        <LinearLayout
            android:id="@+id/processing_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_md"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminateTint="@color/primary_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/scan_processing"
                android:textColor="@color/primary_light"
                android:textSize="@dimen/text_body" />
        </LinearLayout>
    </LinearLayout>

    <!-- Permission Required View (hidden by default) -->
    <LinearLayout
        android:id="@+id/permission_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/background"
        android:padding="@dimen/spacing_xl"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_scan"
            app:tint="@color/text_hint"
            android:contentDescription="Camera" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/scan_permission_required"
            android:textSize="@dimen/text_subtitle"
            android:textColor="@color/text_primary"
            android:textAlignment="center"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_grant_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/scan_grant_permission"
            style="@style/Widget.FreshnessAI.Button.Primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
